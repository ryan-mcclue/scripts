EOF
}

create_readme() {
cat <<EOF > README.md
<!-- SPDX-License-Identifier: zlib-acknowledgement -->

# ${project_abbrev^^} (${project_name})
> ![Github](https://img.shields.io/github/license/ryan-mcclue/${project_abbrev})
EOF
}

create_codefiles() {
  mkdir -p code tests misc work
cat <<EOF > code/${project_abbrev}.c
// SPDX-License-Identifier: zlib-acknowledgement

int
main(void)
{
  return 0;
}
EOF

cat <<EOF > tests/test-${project_abbrev}.c
// SPDX-License-Identifier: zlib-acknowledgement

#include <stdarg.h>
#include <stdint.h>
#include <stddef.h>
#include <setjmp.h>
#include <limits.h>
#include "cmocka.h"

void
test_${project_abbrev}(void **state)
{
 some_assert_here
}

int 
main(void)
{
	const struct CMUnitTest tests[] = {
    // cmocka_unit_test_setup_teardown(test, setup, teardown),
    cmocka_unit_test(test_Element0ShouldReturn1),
    cmocka_unit_test(test_Element2ShouldReturn2),
    cmocka_unit_test(test_ElementNShouldReturnPartOfSequence),
    cmocka_unit_test(test_NegativeElementsShouldReturn0),
    cmocka_unit_test(test_ElementThatOverflowsShouldReturn0),
  };

  return cmocka_run_group_tests(tests, group_setup, group_teardown);
}
EOF

cat <<EOF > misc/build
#!/bin/sh
# SPDX-License-Identifier: zlib-acknowledgement 

cmake --build build/
EOF
cat <<EOF > misc/run-tests
#!/bin/sh
# SPDX-License-Identifier: zlib-acknowledgement 

Incorporate qemu here!
cmake --build build/ --target test-${project_abbrev} && ctest --test-dir build/
EOF
cat <<EOF > misc/flash
device STM32F429ZI 
si 1
speed 4000
loadbin build/${project_abbrev}.bin 0x8000000
r
g
qc
EOF
cat <<EOF > misc/flash-runner
#!/bin/sh
# SPDX-License-Identifier: zlib-acknowledgement 

JLinkExe -commanderscript misc/flash
EOF
cat <<EOF > misc/lint
EOF

cat <<EOF > work/.gdbinit
EOF
}

create_cmakefiles() {
cat <<EOF > CMakeLists.txt
EOF

mkdir -p cmake/toolchains/
}


create_gitfiles() {
cat <<EOF > .gitignore
# SPDX-License-Identifier: zlib-acknowledgement

*

!.gitignore
!README.md
!LICENSE
!CMakeLists.txt

!cmake/
!cmake/toolchains
!cmake/toolchains/cross
!cmake/toolchains/native
!cmake/**/*.cmake

!misc/
!misc/**/*

!code/
!code/**/*.[chs]
!code/**/*.ld

!tests/
!tests/**/*.[ch]

!work/
!work/.gdbinit
EOF
}


create_license
create_readme
create_cmakefiles
create_codefiles
create_gitfiles

printf "Update README!\n"
printf "Update flash script!\n"
