#!/bin/bash
# SPDX-License-Identifier: zlib-acknowledgement

test ! -n "${1}" -o ! -n "${2}" && printf "usage: ${0} <project-abbrev> '<project-name>'\n" \
  && exit 1
project_abbrev="${1}"
project_name="${2}"

