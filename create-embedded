create_readme() {
cat <<EOF > README.md
<!-- SPDX-License-Identifier: zlib-acknowledgement -->

# ${project_abbrev^^} (${project_name})
> ![Github](https://img.shields.io/github/license/ryan-mcclue/${project_abbrev})
EOF
}

create_cmakefiles() {
mkdir -p cmake/toolchains

wget -O cmake/CPM.cmake \
  https://github.com/cpm-cmake/CPM.cmake/releases/latest/download/get_cpm.cmake

cp "$HOME/prog/personal/scripts/tbc/CMockaTesting.cmake" cmake/
cp "$HOME/prog/personal/scripts/tbc/arm-none-eabi-gcc.cmake" cmake/toolchains
cp "$HOME/prog/personal/scripts/tbc/arm-none-eabi-gcc-mcu.cmake" cmake/toolchains

bsp_driver_files='${BSP_DRIVER_FILES}'
bsp_include_directories='${BSP_INCLUDE_DIRECTORIES}'
bsp_macro_definitions='${BSP_MACRO_DEFINITIONS}'
cmake_objcopy='${CMAKE_OBJCOPY}'
cmake_size='${CMAKE_SIZE}'
compiler_flags='${COMPILER_FLAGS}'
cat <<EOF > CMakeLists.txt
# SPDX-License-Identifier: zlib-acknowledgement

cmake_minimum_required(VERSION 3.20)
project(${project_abbrev^^}
        VERSION 0.0.1
        DESCRIPTION "${project_name}"
        LANGUAGES C)
set_property(GLOBAL PROPERTY C_STANDARD 11)

set(BSP_DRIVER_FILES

)
set(BSP_INCLUDE_DIRECTORIES

) 
set(BSP_MACRO_DEFINITIONS

)

add_executable(${project_abbrev})
target_sources(${project_abbrev} PRIVATE
  ${bsp_driver_files}
  code/${project_abbrev}.c
)
target_include_directories(${project_abbrev} PRIVATE
  ${bsp_include_directories}
  code
)
set(COMPILER_FLAGS "\
  -D${project_abbrev^^}_INTERNAL\
  -D${project_abbrev^^}_SLOW\
  \
  -O0 -g -ggdb3\
  \
  -Werror -Wall -Wextra -pedantic -Warray-bounds=2\
  \
  -Wno-unused-variable -Wno-unused-function -Wno-unused-but-set-variable\
  -Wno-unused-parameter -Wno-missing-field-initializers -Wno-write-strings\
  -Wno-unused-result\
  \
  -fdata-sections -ffunction-sections\
  "
)
target_compile_options(${project_abbrev} PRIVATE
  ${bsp_macro_definitions}
  ${compiler_flags}
)

add_custom_command(
  TARGET ${project_abbrev} POST_BUILD
  COMMAND ${cmake_size} ${project_abbrev}
)
add_custom_command(
  TARGET ${project_abbrev} POST_BUILD
  COMMAND ${cmake_objcopy} ARGS -O binary ${project_abbrev} ${project_abbrev}.bin
  COMMAND ${cmake_objcopy} ARGS -O ihex ${project_abbrev} ${project_abbrev}.hex
)

include(cmake/CPM.cmake)
CPMAddPackage("gl:cmocka/cmocka#cmocka-1.1.5")

include(cmake/CMockaTesting.cmake)
cmocka_add_test(test-${project_abbrev}
  "code/${project_abbrev}.c;tests/test-${project_abbrev}.c"
)
EOF

}

create_codefiles() {
  mkdir -p code tests misc work build
  cp "$HOME/prog/personal/scripts/tbc/create" misc/
  cp "$HOME/prog/personal/scripts/tbc/build" misc/
  cp "$HOME/prog/personal/scripts/tbc/run-tests" misc/
  cp "$HOME/prog/personal/scripts/tbc/flash-runner" misc/
cat <<EOF > code/${project_abbrev}.c
// SPDX-License-Identifier: zlib-acknowledgement

#if defined(TESTING)
  int testable_main(void)
#else
  int main(void)
#endif
{
  return 0;
}
EOF

cat <<EOF > tests/test-${project_abbrev}.c
// SPDX-License-Identifier: zlib-acknowledgement

#include <stdarg.h>
#include <stdint.h>
#include <stddef.h>
#include <setjmp.h>
#include <limits.h>
#include <cmocka.h>

extern int testable_main(void);

void
test_${project_abbrev}(void **state)
{
  assert_int_equal(testable_main(), 0);
}

int 
main(void)
{
	const struct CMUnitTest tests[] = {
    cmocka_unit_test(test_${project_abbrev}),
  };

  return cmocka_run_group_tests(tests, NULL, NULL);
}
EOF
cat <<EOF > misc/flash
device STM32F429ZI 
si 1
speed 4000
loadbin build/${project_abbrev}.bin 0x8000000
r
g
qc
EOF
cat <<EOF > misc/lint
#!/bin/sh
# SPDX-License-Identifier: zlib-acknowledgement 

EOF
chmod +x misc/flash misc/lint
}

create_cmakefiles
create_codefiles

